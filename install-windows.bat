:: ‚ĒÄ‚ĒÄ –•–Ķ–Ľ–Ņ–Ķ—Ä –ī–Ľ—Ź —Ā–ļ–į—á–ł–≤–į–Ĺ–ł—Ź / Download helper ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
:: PowerShell –≥–į—Ä–į–Ĺ—ā–ł—Ä–ĺ–≤–į–Ĺ–Ĺ–ĺ –Ķ—Ā—ā—Ć, curl ‚ÄĒ –Ĺ–Ķ—ā –Ĺ–į —Ā—ā–į—Ä—č—Ö Windows
:: PowerShell is guaranteed, curl may be absent on older Windows

mkdir "%INSTALL_DIR%" 2>nul
mkdir "%TOOLS_DIR%" 2>nul

:: ‚ĒÄ‚ĒÄ 1. –ü—Ä–ĺ–≤–Ķ—Ä–ļ–į Java / Check Java ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo   [+] –ü—Ä–ĺ–≤–Ķ—Ä–ļ–į Java... / Checking Java...
java -version >nul 2>&1
if !errorLevel! neq 0 (
    echo.
    echo   [!] Java –Ĺ–Ķ –Ĺ–į–Ļ–ī–Ķ–Ĺ–į! / Java not found!

    :: –ü—Ä–ĺ–Ī—É–Ķ–ľ winget
    where winget >nul 2>&1
    if !errorLevel! equ 0 (
        echo   [*] –£—Ā—ā–į–Ĺ–ĺ–≤–ļ–į Java —á–Ķ—Ä–Ķ–∑ winget... / Installing Java via winget...
        winget install --id EclipseAdoptium.Temurin.17.JRE -e --accept-source-agreements --accept-package-agreements 2>nul
        goto :java_check
    )

    :: –ü—Ä–ĺ–Ī—É–Ķ–ľ choco
    where choco >nul 2>&1
    if !errorLevel! equ 0 (
        echo   [*] –£—Ā—ā–į–Ĺ–ĺ–≤–ļ–į Java —á–Ķ—Ä–Ķ–∑ chocolatey... / Installing Java via chocolatey...
        choco install temurin17jre -y 2>nul
        goto :java_check
    )

    :: –Ě–ł winget –Ĺ–ł choco ‚ÄĒ —Ā—ā–į–≤–ł–ľ choco
    echo   [*] –ü–į–ļ–Ķ—ā–Ĺ—č–Ļ –ľ–Ķ–Ĺ–Ķ–ī–∂–Ķ—Ä –Ĺ–Ķ –Ĺ–į–Ļ–ī–Ķ–Ĺ, —É—Ā—ā–į–Ĺ–ĺ–≤–ļ–į Chocolatey... / No package manager found, installing Chocolatey...
    powershell -NoProfile -ExecutionPolicy Bypass -Command ^
        "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; iex ((New-Object Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))" >nul 2>&1
    set "PATH=%ALLUSERSPROFILE%\chocolatey\bin;!PATH!"

    where choco >nul 2>&1
    if !errorLevel! equ 0 (
        echo   [+] Chocolatey —É—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ. / Chocolatey installed.
        echo   [*] –£—Ā—ā–į–Ĺ–ĺ–≤–ļ–į Java —á–Ķ—Ä–Ķ–∑ chocolatey... / Installing Java via chocolatey...
        choco install temurin17jre -y 2>nul
    ) else (
        echo   [*] –°–ļ–į—á–ł–≤–į–Ķ–ľ Java –Ĺ–į–Ņ—Ä—Ź–ľ—É—é... / Downloading Java directly...
        powershell -NoProfile -Command ^
            "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; (New-Object Net.WebClient).DownloadFile('https://api.adoptium.net/v3/binary/latest/17/ga/windows/x64/jre/hotspot/normal/eclipse', '%TEMP%\java-jre.zip')" 2>nul
        if exist "%TEMP%\java-jre.zip" (
            echo   [*] –†–į—Ā–Ņ–į–ļ–ĺ–≤–ļ–į Java... / Extracting Java...
            powershell -Command "Expand-Archive -Force '%TEMP%\java-jre.zip' '%INSTALL_DIR%\java'" >nul 2>&1
            for /d %%D in ("%INSTALL_DIR%\java\*") do set "JAVA_HOME=%%D"
            if defined JAVA_HOME (
                set "PATH=!JAVA_HOME!\bin;!PATH!"
                setx /M JAVA_HOME "!JAVA_HOME!" >nul 2>&1
                for /f "tokens=2*" %%A in ('reg query "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Environment" /v Path 2^>nul') do set "SYS_PATH=%%B"
                setx /M PATH "!JAVA_HOME!\bin;!SYS_PATH!" >nul 2>&1
            )
            del /q "%TEMP%\java-jre.zip" 2>nul
        )
    )

:java_check
    :: –ě–Ī–Ĺ–ĺ–≤–Ľ—Ź–Ķ–ľ PATH –ł–∑ —Ä–Ķ–Ķ—Ā—ā—Ä–į / Refresh PATH from registry
    for /f "tokens=2*" %%A in ('reg query "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Environment" /v Path 2^>nul') do set "PATH=%%B"
    for /f "tokens=2*" %%A in ('reg query "HKCU\Environment" /v Path 2^>nul') do set "PATH=!PATH!;%%B"
    set "PATH=%ALLUSERSPROFILE%\chocolatey\bin;!PATH!"

    java -version >nul 2>&1
    if !errorLevel! neq 0 (
        echo   [!] Java –Ĺ–Ķ —É—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–į. –°–ļ–į—á–į–Ļ—ā–Ķ –≤—Ä—É—á–Ĺ—É—é: https://adoptium.net/
        echo   [!] Java not installed. Download manually: https://adoptium.net/
        pause
        exit /b 1
    )
)
echo   [+] Java OK.

:: ‚ĒÄ‚ĒÄ 2. apktool 2.10.0 ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo   [+] –ü—Ä–ĺ–≤–Ķ—Ä–ļ–į apktool... / Checking apktool...
set "APKTOOL_OK=0"
apktool --version >nul 2>&1
if !errorLevel! equ 0 set "APKTOOL_OK=1"

if "!APKTOOL_OK!"=="0" (
    echo   [*] –£—Ā—ā–į–Ĺ–ĺ–≤–ļ–į apktool 2.10.0... / Installing apktool 2.10.0...

    powershell -NoProfile -Command ^
        "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; (New-Object Net.WebClient).DownloadFile('https://bitbucket.org/iBotPeaches/apktool/downloads/apktool_2.10.0.jar', '%TOOLS_DIR%\apktool.jar')" 2>nul

    :: –ü—Ä–ĺ–≤–Ķ—Ä—Ź–Ķ–ľ —á—ā–ĺ —Ā–ļ–į—á–į–Ľ—Ā—Ź JAR, –į –Ĺ–Ķ HTML
    powershell -NoProfile -Command ^
        "$f = '%TOOLS_DIR%\apktool.jar'; if ((Test-Path $f) -and (Get-Item $f).Length -gt 100000) { exit 0 } else { exit 1 }" 2>nul
    if !errorLevel! neq 0 (
        echo   [*] Bitbucket –Ĺ–Ķ –ĺ—ā–ī–į–Ľ, –ļ–į—á–į–Ķ–ľ —Ā GitHub... / Bitbucket failed, trying GitHub...
        powershell -NoProfile -Command ^
            "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; (New-Object Net.WebClient).DownloadFile('https://github.com/iBotPeaches/Apktool/releases/download/v2.10.0/apktool_2.10.0.jar', '%TOOLS_DIR%\apktool.jar')" 2>nul
    )

    (
        echo @echo off
        echo java -jar "%TOOLS_DIR%\apktool.jar" %%*
    ) > "%TOOLS_DIR%\apktool.bat"

    echo   [+] apktool —É—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ. / apktool installed.
)

:: ‚ĒÄ‚ĒÄ 3. Android build-tools (apksigner + zipalign) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo   [+] –ü—Ä–ĺ–≤–Ķ—Ä–ļ–į Android build-tools... / Checking Android build-tools...
set "NEED_BT=0"

set "PATH=%TOOLS_DIR%;!PATH!"
apksigner --version >nul 2>&1
if !errorLevel! neq 0 set "NEED_BT=1"

if "!NEED_BT!"=="1" (
    echo   [*] –£—Ā—ā–į–Ĺ–ĺ–≤–ļ–į Android build-tools... / Installing Android build-tools...
    powershell -NoProfile -Command ^
        "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; (New-Object Net.WebClient).DownloadFile('https://dl.google.com/android/repository/build-tools_r35-windows.zip', '%TEMP%\bt.zip')" 2>nul

    if exist "%TEMP%\bt.zip" (
        powershell -NoProfile -Command "Expand-Archive -Force '%TEMP%\bt.zip' '%TEMP%\bt-extract'" >nul 2>&1

        :: –Ě–į–Ļ—ā–ł –Ņ–į–Ņ–ļ—É –≤–Ĺ—É—ā—Ä–ł –į—Ä—Ö–ł–≤–į / Find folder inside archive
        set "BT_FOUND="
        for /d %%D in ("%TEMP%\bt-extract\*") do (
            if exist "%%D\zipalign.exe" set "BT_FOUND=%%D"
        )

        if defined BT_FOUND (
            copy /y "!BT_FOUND!\zipalign.exe" "%TOOLS_DIR%\" >nul 2>&1
            if exist "!BT_FOUND!\apksigner.bat" copy /y "!BT_FOUND!\apksigner.bat" "%TOOLS_DIR%\" >nul 2>&1
            if exist "!BT_FOUND!\apksigner.jar" copy /y "!BT_FOUND!\apksigner.jar" "%TOOLS_DIR%\" >nul 2>&1
            if exist "!BT_FOUND!\lib" xcopy /E /I /Y /Q "!BT_FOUND!\lib" "%TOOLS_DIR%\lib" >nul 2>&1
            echo   [+] build-tools —É—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ—č. / build-tools installed.
        ) else (
            echo   [!] –Ě–Ķ —É–ī–į–Ľ–ĺ—Ā—Ć –Ĺ–į–Ļ—ā–ł build-tools –≤ –į—Ä—Ö–ł–≤–Ķ. / Could not find build-tools in archive.
        )

        rd /s /q "%TEMP%\bt-extract" 2>nul
        del /q "%TEMP%\bt.zip" 2>nul
    ) else (
        echo   [!] –Ě–Ķ —É–ī–į–Ľ–ĺ—Ā—Ć —Ā–ļ–į—á–į—ā—Ć build-tools. / Failed to download build-tools.
    )
)

:: –Ē–ĺ–Ī–į–≤–Ľ—Ź–Ķ–ľ tools –≤ —Ā–ł—Ā—ā–Ķ–ľ–Ĺ—č–Ļ PATH / Add tools to system PATH
for /f "tokens=2*" %%A in ('reg query "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Environment" /v Path 2^>nul') do set "SYS_PATH=%%B"
echo !SYS_PATH! | find /i "%TOOLS_DIR%" >nul 2>&1
if !errorLevel! neq 0 (
    setx /M PATH "!SYS_PATH!;%TOOLS_DIR%" >nul 2>&1
)
set "PATH=%TOOLS_DIR%;!PATH!"

:: –§–ł–Ĺ–į–Ľ—Ć–Ĺ–į—Ź –Ņ—Ä–ĺ–≤–Ķ—Ä–ļ–į / Final check
apksigner --version >nul 2>&1
if !errorLevel! neq 0 (
    echo   [!] apksigner –Ĺ–Ķ —Ä–į–Ī–ĺ—ā–į–Ķ—ā. –£—Ā—ā–į–Ĺ–ĺ–≤–ł—ā–Ķ Android SDK build-tools –≤—Ä—É—á–Ĺ—É—é.
    echo   [!] apksigner not working. Install Android SDK build-tools manually.
    pause
    exit /b 1
)
echo   [+] apksigner OK.

:: ‚ĒÄ‚ĒÄ 4. –†–į–∑–≤—Ď—Ä—ā—č–≤–į–Ĺ–ł–Ķ —Ą–į–Ļ–Ľ–ĺ–≤ / Deploy files ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo   [+] –†–į–∑–≤—Ď—Ä—ā—č–≤–į–Ĺ–ł–Ķ –≤ %INSTALL_DIR%... / Deploying to %INSTALL_DIR%...
mkdir "%INSTALL_DIR%\data" 2>nul

copy /y "%SCRIPT_DIR%bin\windows\server.exe" "%INSTALL_DIR%\server.exe" >nul

:: –ß–ł—Ā—ā–ł–ľ —Ā—ā–į—Ä–ĺ–Ķ –Ņ–Ķ—Ä–Ķ–ī –ļ–ĺ–Ņ–ł—Ä–ĺ–≤–į–Ĺ–ł–Ķ–ľ / Clean old before copying
if exist "%INSTALL_DIR%\decom" rd /s /q "%INSTALL_DIR%\decom" 2>nul
if exist "%INSTALL_DIR%\web"   rd /s /q "%INSTALL_DIR%\web" 2>nul
xcopy /E /I /Y /Q "%SCRIPT_DIR%source\decom" "%INSTALL_DIR%\decom" >nul
xcopy /E /I /Y /Q "%SCRIPT_DIR%source\web" "%INSTALL_DIR%\web" >nul

echo   [+] –§–į–Ļ–Ľ—č —Ä–į–∑–≤—Ď—Ä–Ĺ—É—ā—č. / Files deployed.

:: ‚ĒÄ‚ĒÄ 5. –Ě–į—Ā—ā—Ä–ĺ–Ļ–ļ–į / Configuration ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo.
echo   ‚ĒÄ‚ĒÄ –Ě–į—Ā—ā—Ä–ĺ–Ļ–ļ–į / Configuration ‚ĒÄ‚ĒÄ
echo.

:: IP —á–Ķ—Ä–Ķ–∑ PowerShell (curl –ľ–ĺ–∂–Ķ—ā –Ĺ–Ķ –Ī—č—ā—Ć) / IP via PowerShell
for /f "tokens=*" %%i in ('powershell -NoProfile -Command "try { (New-Object Net.WebClient).DownloadString('https://ifconfig.me').Trim() } catch { '' }" 2^>nul') do set "EXTERNAL_IP=%%i"

:: –õ–ĺ–ļ–į–Ľ—Ć–Ĺ—č–Ļ IP –Ī–Ķ–∑ –Ņ—Ä–ł–≤—Ź–∑–ļ–ł –ļ —Ź–∑—č–ļ—É / Local IP without locale dependency
if not defined EXTERNAL_IP (
    for /f "tokens=*" %%i in ('powershell -NoProfile -Command "(Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.PrefixOrigin -ne 'WellKnown' -and $_.IPAddress -ne '127.0.0.1' } | Select-Object -First 1).IPAddress" 2^>nul') do set "EXTERNAL_IP=%%i"
)
set "DEFAULT_IP=%EXTERNAL_IP%"

set /p "SERVER_IP=  [?] IP –ī–Ľ—Ź APK-–Ī–ł–Ľ–ī–ĺ–≤ / IP for APK builds (Enter = %DEFAULT_IP%): "
if "!SERVER_IP!"=="" set "SERVER_IP=!DEFAULT_IP!"

set /p "PORT=  [?] –ü–ĺ—Ä—ā / Port (Enter = 8080): "
if "!PORT!"=="" set "PORT=8080"

set /p "REG_MODE=  [?] –†–Ķ–≥–ł—Ā—ā—Ä–į—Ü–ł—Ź / Registration ‚ÄĒ open / closed (Enter = closed): "
if "!REG_MODE!"=="" set "REG_MODE=closed"

:: ‚ĒÄ‚ĒÄ 6. –ė–Ĺ–ł—Ü–ł–į–Ľ–ł–∑–į—Ü–ł—Ź / Initialization ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
echo.
echo   [+] –ė–Ĺ–ł—Ü–ł–į–Ľ–ł–∑–į—Ü–ł—Ź —Ā–Ķ—Ä–≤–Ķ—Ä–į... / Initializing server...

:: –£–Ī–ł–≤–į–Ķ–ľ —Ā—ā–į—Ä—č–Ļ –Ņ—Ä–ĺ—Ü–Ķ—Ā—Ā –Ķ—Ā–Ľ–ł –Ķ—Ā—ā—Ć / Kill old process if running
taskkill /f /im server.exe >nul 2>&1

set "INIT_INPUT=%TEMP%\redwing-init-input.txt"
set "INIT_LOG=%TEMP%\redwing-init-log.txt"

if "!REG_MODE!"=="closed" (
    set /p "ADMIN_LOGIN=  [?] –õ–ĺ–≥–ł–Ĺ –į–ī–ľ–ł–Ĺ–į / Admin login (Enter = admin): "
